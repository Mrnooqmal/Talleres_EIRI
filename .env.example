SECRET_KEY=cambia-esto-por-algo-aleatorio-largo
JWT_SECRET=cambia-esto-por-algo-aleatorio-largo
PORT=3000
NODE_ENV=production

# Base de datos: si no se define TURSO_DATABASE_URL, usa archivo local (file:eiri.db)
# Para Vercel/serverless, usar Turso:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Almacenamiento de archivos en S3 (opcional en EC2, obligatorio en Vercel).
# Si S3_BUCKET esta vacio, las subidas van al disco local en static/uploads.
# En EC2 las credenciales se toman del rol IAM de la instancia (no pongas llaves aqui).
S3_BUCKET=
AWS_REGION=sa-east-1
# Dominio de CloudFront para servir las imagenes (sin barra final)
S3_PUBLIC_URL=
